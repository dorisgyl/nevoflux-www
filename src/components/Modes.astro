---
import { getLocale, getUI } from '~/utils/i18n';

const locale = getLocale(Astro.url);
const ui = getUI(locale);

const modes = [
  {
    ...ui.modes.chat,
    icon: `<path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>`,
    color: 'from-blue-500/20 to-blue-600/5',
    border: 'border-blue-500/20',
    iconBg: 'bg-blue-500/10 text-blue-600',
  },
  {
    ...ui.modes.browser,
    icon: `<rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/>`,
    color: 'from-accent/20 to-accent/5',
    border: 'border-accent/20',
    iconBg: 'bg-accent/10 text-accent',
  },
  {
    ...ui.modes.agent,
    icon: `<path d="M12 2a4 4 0 0 1 4 4v1a2 2 0 0 1 2 2v2a2 2 0 0 1-2 2h-1l-1 7H10l-1-7H8a2 2 0 0 1-2-2V9a2 2 0 0 1 2-2V6a4 4 0 0 1 4-4z"/><circle cx="9" cy="8" r="1"/><circle cx="15" cy="8" r="1"/>`,
    color: 'from-purple-500/20 to-purple-600/5',
    border: 'border-purple-500/20',
    iconBg: 'bg-purple-500/10 text-purple-600',
  },
];
---

<section class="bg-surface/30 py-24 lg:py-32">
  <div class="container">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight md:text-5xl">{ui.modes.title}</h2>
      <p class="mt-4 text-lg text-subtle">{ui.modes.subtitle}</p>
    </div>

    <div class="mt-16 grid gap-8 md:grid-cols-3">
      {
        modes.map((mode, i) => (
          <div
            class={`relative overflow-hidden rounded-2xl border ${mode.border} bg-gradient-to-b ${mode.color} p-8 transition-all hover:scale-[1.02]`}
          >
            <div class="text-dark/5 absolute right-4 top-4 text-6xl font-bold">{i + 1}</div>

            <div
              class={`mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl ${mode.iconBg}`}
            >
              <svg
                class="h-6 w-6"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <Fragment set:html={mode.icon} />
              </svg>
            </div>

            <h3 class="text-2xl font-bold">{mode.title}</h3>
            <p class="mt-3 leading-relaxed text-subtle">{mode.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
