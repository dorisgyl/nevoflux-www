---
import { getLocale, getUI } from '~/utils/i18n';

const locale = getLocale(Astro.url);
const ui = getUI(locale);

const features = [
  {
    icon: `<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>`,
    ...ui.features.identity,
  },
  {
    icon: `<path d="M12 2v4m0 12v4M2 12h4m12 0h4"/><circle cx="12" cy="12" r="3"/>`,
    ...ui.features.memory,
  },
  {
    icon: `<path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/>`,
    ...ui.features.autonomy,
  },
  {
    icon: `<rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/><path d="M7 10h2m4 0h4"/>`,
    ...ui.features.systemControl,
  },
  {
    icon: `<rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/>`,
    ...ui.features.canvas,
  },
  {
    icon: `<circle cx="12" cy="12" r="3"/><path d="M12 1v4M12 19v4M4.22 4.22l2.83 2.83M16.95 16.95l2.83 2.83M1 12h4M19 12h4M4.22 19.78l2.83-2.83M16.95 7.05l2.83-2.83"/>`,
    ...ui.features.agentEcosystem,
  },
];
---

<section id="features" class="py-24 lg:py-32">
  <div class="container">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="text-3xl font-bold tracking-tight md:text-5xl">{ui.features.title}</h2>
      <p class="mt-4 text-lg text-subtle">{ui.features.subtitle}</p>
    </div>

    <div class="mt-16 grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
      {
        features.map((feature) => (
          <div class="border-dark/10 bg-surface/50 hover:border-accent/30 hover:shadow-accent/5 group rounded-2xl border p-8 transition-all hover:shadow-lg">
            <div class="bg-accent/10 mb-4 inline-flex h-12 w-12 items-center justify-center rounded-xl text-accent">
              <svg
                class="h-6 w-6"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <Fragment set:html={feature.icon} />
              </svg>
            </div>
            <h3 class="text-xl font-semibold">{feature.title}</h3>
            <p class="mt-2 leading-relaxed text-subtle">{feature.description}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>
