---
import { getLocale, getUI, getPath, getAlternateUrl } from '~/utils/i18n';
import { GITHUB_URL } from '~/constants';
import Logo from './Logo.astro';

const locale = getLocale(Astro.url);
const ui = getUI(locale);
const alternateUrl = getAlternateUrl(Astro.url);
---

<nav class="border-dark/10 bg-paper/80 fixed top-0 z-50 w-full border-b backdrop-blur-md">
  <div class="container flex h-16 items-center justify-between">
    <a href={getPath(locale, '/')} class="flex items-center gap-2.5">
      <Logo size={28} />
      <span class="text-lg font-bold tracking-tight">
        <span class="text-accent">Nevo</span>Flux
      </span>
    </a>

    <div class="flex items-center gap-4 sm:gap-6">
      <a
        href="#features"
        class="hidden text-sm font-medium text-subtle transition-colors hover:text-accent sm:block"
      >
        {ui.nav.features}
      </a>

      <!-- Language switcher -->
      <a
        href={alternateUrl}
        class="hover:bg-accent/5 inline-flex items-center gap-1 rounded-md px-2 py-1 text-xs font-medium text-muted transition-colors hover:text-accent"
        title={ui.lang.switchTo}
      >
        <svg
          class="h-3.5 w-3.5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <circle cx="12" cy="12" r="10"></circle>
          <path d="M2 12h20"></path>
          <path
            d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"
          ></path>
        </svg>
        {ui.lang.switchTo}
      </a>

      <!-- GitHub -->
      <a
        href={GITHUB_URL}
        class="border-dark/10 hover:border-accent/30 inline-flex items-center gap-1.5 rounded-lg border px-3 py-1.5 text-sm font-medium text-subtle transition-colors hover:text-accent"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="currentColor">
          <path
            d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
          ></path>
        </svg>
        <span class="hidden sm:inline">{ui.nav.github}</span>
      </a>
    </div>
  </div>
</nav>
