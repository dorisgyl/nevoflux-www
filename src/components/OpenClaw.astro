---
import { getLocale, getUI } from '~/utils/i18n';

const locale = getLocale(Astro.url);
const ui = getUI(locale);
---

<section class="bg-surface/30 py-24 lg:py-32">
  <div class="container">
    <div class="mx-auto max-w-4xl">
      <div
        class="via-accent/5 relative overflow-hidden rounded-3xl border border-purple-500/20 bg-gradient-to-br from-purple-500/10 to-transparent p-10 md:p-14"
      >
        <!-- Background decoration -->
        <div class="absolute -right-20 -top-20 h-60 w-60 rounded-full bg-purple-500/5 blur-[80px]">
        </div>

        <div class="relative z-10">
          <!-- Badge -->
          <div
            class="mb-6 inline-flex items-center gap-2 rounded-full border border-purple-500/20 bg-purple-500/10 px-4 py-1.5 text-sm font-medium text-purple-600"
          >
            <svg
              class="h-4 w-4"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
            >
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
              <circle cx="12" cy="7" r="4"></circle>
              <path d="M16 3.13a4 4 0 0 1 0 7.75"></path>
            </svg>
            {ui.openclaw.subtitle}
          </div>

          <h2 class="text-3xl font-bold tracking-tight md:text-4xl">{ui.openclaw.title}</h2>
          <p class="mt-4 max-w-2xl text-lg leading-relaxed text-subtle">
            {ui.openclaw.description}
          </p>

          <!-- Three feature cards -->
          <div class="mt-10 grid gap-6 sm:grid-cols-3">
            <div class="border-dark/10 bg-surface/50 rounded-2xl border p-6">
              <div
                class="bg-accent/10 mb-3 inline-flex h-10 w-10 items-center justify-center rounded-lg text-accent"
              >
                <svg
                  class="h-5 w-5"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <rect x="3" y="3" width="7" height="7"></rect>
                  <rect x="14" y="3" width="7" height="7"></rect>
                  <rect x="14" y="14" width="7" height="7"></rect>
                  <rect x="3" y="14" width="7" height="7"></rect>
                </svg>
              </div>
              <h3 class="text-lg font-semibold">{ui.openclaw.integrations}</h3>
              <p class="mt-1 text-sm leading-relaxed text-subtle">{ui.openclaw.integrationsDesc}</p>
            </div>

            <div class="border-dark/10 bg-surface/50 rounded-2xl border p-6">
              <div
                class="mb-3 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-blue-500/10 text-blue-600"
              >
                <svg
                  class="h-5 w-5"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <rect x="2" y="3" width="20" height="14" rx="2"></rect>
                  <path d="M8 21h8M12 17v4"></path>
                  <path d="M7 10h2m4 0h4"></path>
                </svg>
              </div>
              <h3 class="text-lg font-semibold">{ui.openclaw.browserUse}</h3>
              <p class="mt-1 text-sm leading-relaxed text-subtle">{ui.openclaw.browserUseDesc}</p>
            </div>

            <div class="border-dark/10 bg-surface/50 rounded-2xl border p-6">
              <div
                class="mb-3 inline-flex h-10 w-10 items-center justify-center rounded-lg bg-purple-500/10 text-purple-600"
              >
                <svg
                  class="h-5 w-5"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
                </svg>
              </div>
              <h3 class="text-lg font-semibold">{ui.openclaw.openSource}</h3>
              <p class="mt-1 text-sm leading-relaxed text-subtle">{ui.openclaw.openSourceDesc}</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
