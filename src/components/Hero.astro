---
import { getLocale, getUI } from '~/utils/i18n';
import { GITHUB_URL } from '~/constants';
import Button from './Button.astro';

const locale = getLocale(Astro.url);
const ui = getUI(locale);

const DOWNLOAD_BASE = `${GITHUB_URL}/releases/latest`;
---

<section class="relative flex min-h-screen items-center justify-center overflow-hidden pt-16">
  <!-- Background gradient -->
  <div class="from-accent/5 absolute inset-0 bg-gradient-to-b via-transparent to-transparent"></div>
  <div
    class="bg-glow/10 absolute left-1/2 top-1/4 h-[500px] w-[500px] -translate-x-1/2 -translate-y-1/2 rounded-full blur-[120px]"
  >
  </div>

  <div class="container relative z-10 text-center">
    <!-- Tagline badge -->
    <div
      class="border-accent/20 bg-accent/5 inline-flex animate-fadeIn items-center gap-2 rounded-full border px-4 py-1.5 text-sm font-medium text-accent"
    >
      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"></path>
      </svg>
      {ui.hero.tagline}
    </div>

    <!-- Main title -->
    <h1
      class="mt-8 animate-fadeIn text-5xl font-bold tracking-tight text-dark md:text-7xl lg:text-8xl"
      style="animation-delay: 0.2s; animation-fill-mode: both;"
    >
      {ui.hero.title}
    </h1>

    <!-- Subtitle -->
    <p
      class="mx-auto mt-6 max-w-2xl animate-fadeIn text-lg text-subtle md:text-xl"
      style="animation-delay: 0.4s; animation-fill-mode: both;"
    >
      {ui.hero.subtitle}
    </p>

    <!-- CTA buttons -->
    <div
      class="mt-10 flex animate-fadeIn flex-wrap items-center justify-center gap-4"
      style="animation-delay: 0.6s; animation-fill-mode: both;"
    >
      <!-- Download button with OS detection -->
      <a
        id="download-btn"
        href={DOWNLOAD_BASE}
        class="shadow-accent/20 inline-flex items-center justify-center rounded-lg bg-accent px-6 py-3 text-sm font-medium text-white shadow-lg transition-colors hover:bg-accent-hover"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg
          class="mr-2 h-5 w-5"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
          <polyline points="7 10 12 15 17 10"></polyline>
          <line x1="12" y1="15" x2="12" y2="3"></line>
        </svg>
        <span id="download-text">{ui.hero.downloadGeneric}</span>
      </a>

      <Button href={GITHUB_URL} variant="secondary" target="_blank" rel="noopener noreferrer">
        <svg class="mr-2 h-5 w-5" viewBox="0 0 24 24" fill="currentColor">
          <path
            d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
          ></path>
        </svg>
        {ui.hero.github}
      </Button>
    </div>
  </div>
</section>

<script define:vars={{ downloadTemplate: ui.hero.download, githubUrl: GITHUB_URL }}>
  // OS + architecture detection and download link update with GitHub API
  (function () {
    const ua = navigator.userAgent.toLowerCase();
    let os = '';
    let osLabel = '';
    /** @type {string[]} */
    let extensions = [];

    if (ua.includes('win')) {
      os = 'windows';
      osLabel = 'Windows';
      extensions = ['.exe', '.msi'];
    } else if (ua.includes('mac')) {
      os = 'macos';
      osLabel = 'macOS';
      extensions = ['.dmg', '.pkg'];
    } else if (ua.includes('linux')) {
      os = 'linux';
      osLabel = 'Linux';
      extensions = ['.AppImage', '.deb', '.rpm'];
    }

    // Detect CPU architecture
    const arch = (function () {
      const platform = (navigator.platform || '').toLowerCase();
      if (platform.includes('aarch64') || platform.includes('arm')) return 'arm64';
      if (ua.includes('aarch64') || ua.includes('arm64')) return 'arm64';
      return 'x64';
    })();

    // Identifiers commonly used in release asset filenames
    const archTags = arch === 'arm64' ? ['aarch64', 'arm64'] : ['x86_64', 'x86-64', 'x64', 'amd64'];

    const textEl = document.getElementById('download-text');
    const btnEl = document.getElementById('download-btn');

    // Update button text immediately based on OS
    if (os && textEl) {
      textEl.textContent = downloadTemplate.replace('{os}', osLabel);
    }

    // Fetch latest release from GitHub API to get direct download link
    if (os && btnEl) {
      const apiUrl = githubUrl
        .replace('github.com', 'api.github.com/repos')
        .concat('/releases/latest');

      fetch(apiUrl)
        .then((res) => (res.ok ? res.json() : Promise.reject()))
        .then((release) => {
          const assets = release.assets || [];

          // Helper: check if asset name matches any of the given arch tags
          const matchesArch = (name) => archTags.some((tag) => name.includes(tag));

          for (const ext of extensions) {
            const extLower = ext.toLowerCase();
            const candidates = assets.filter((a) => a.name.toLowerCase().endsWith(extLower));
            // Prefer the asset whose name contains the detected arch tag
            const archMatch = candidates.find((a) => matchesArch(a.name.toLowerCase()));
            const match = archMatch || candidates[0];
            if (match) {
              btnEl.setAttribute('href', match.browser_download_url);
              return;
            }
          }
        })
        .catch(() => {
          // Keep default link to releases/latest page
        });
    }
  })();
</script>
